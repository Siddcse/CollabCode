# ─────────────────────────────────────────
# CollabCode — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
NODE_ENV=production
PORT=4000

# ── MongoDB ──────────────────────────────
# Get this from MongoDB Atlas: Deployments > Connect > Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/collabcode?retryWrites=true&w=majority

# ── Redis (optional) ─────────────────────
# Leave empty to run without Redis (OT state stored in memory)
REDIS_URL=redis://default:password@redis-host:6379

# ── JWT / Auth ───────────────────────────
# Generate a strong random key (at least 32 chars)
# On Railway, this MUST be set via Railway dashboard
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────
# Set to your frontend URL (Vercel, Netlify, etc.)
CORS_ORIGIN=https://your-frontend-url.vercel.app

# ── Code Execution ───────────────────────
# On Railway/Production, Docker is usually not available,
# so code runs via host runtimes (Java, Python, GCC, etc.)
DOCKER_SOCKET_PATH=

EXECUTION_TIMEOUT_MS=10000
EXECUTION_MEMORY_LIMIT=134217728
EXECUTION_CPU_QUOTA=50000

# ── Rate Limiting ────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ── Frontend (Next.js) ───────────────────
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Production (set these in Vercel dashboard):
# NEXT_PUBLIC_WS_URL=https://collabcode-backend.up.railway.app
# NEXT_PUBLIC_API_URL=https://collabcode-backend.up.railway.app/api
