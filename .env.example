# ─────────────────────────────────────────
# CollabCode — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MongoDB ──────────────────────────────
MONGODB_URI=mongodb://localhost:27017/collabcode
# Production: MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/collabcode

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: REDIS_URL=redis://<user>:<pass>@<host>:6379

# ── JWT / Auth ───────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────
CORS_ORIGIN=http://localhost:3000
# Production: CORS_ORIGIN=https://collabcode.vercel.app

# ── Docker Execution ─────────────────────
# Windows (Named Pipe — SECURE):
DOCKER_SOCKET_PATH=//./pipe/docker_engine
# Linux/Mac (Unix socket):
# DOCKER_SOCKET_PATH=/var/run/docker.sock

EXECUTION_TIMEOUT_MS=10000
EXECUTION_MEMORY_LIMIT=134217728
EXECUTION_CPU_QUOTA=50000

# ── Rate Limiting ────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ── Frontend (Next.js) ───────────────────
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Production:
# NEXT_PUBLIC_WS_URL=https://collabcode-backend.up.railway.app
# NEXT_PUBLIC_API_URL=https://collabcode-backend.up.railway.app/api
